{
  "manifest_version": 3,
  "name": "Reframe",
  "version": "1.0.0",
  "description": "Detects blacklisted content and replaces it with article-based content from your preferred topics.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://newsfeed-hhtk.onrender.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/logo_small.png",
      "48": "icons/logo_small.png",
      "128": "icons/logo_small.png"
    }
  },
  "icons": {
    "16": "icons/logo_small.png",
    "48": "icons/logo_small.png",
    "128": "icons/logo_small.png"
  }
}
